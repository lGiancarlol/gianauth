# ── Copy to .env and fill in values ──────────────────────────────────────────
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_min_32_chars

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, single server)
DATABASE_URL=file:./prisma/dev.db

# PostgreSQL (uncomment to use instead of SQLite)
# DATABASE_URL=postgresql://user:password@db:5432/gianauth

# ── Discord webhook (optional — for request notifications without bot) ────────
DISCORD_WEBHOOK_URL=

# ── Discord bot (optional — required only if running the bot service) ─────────
# Get from: https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Application ID from: Discord Developer Portal → Your App → General Information
DISCORD_CLIENT_ID=your_discord_application_id_here

# Channel ID where request notifications will be sent
# Right-click a channel in Discord → Copy Channel ID (requires Developer Mode)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Owner JWT token for bot to call the API
# Get by logging in: POST /api/auth/login → copy the token field
OWNER_API_TOKEN=your_owner_jwt_token_here

# Backend API URL as seen from the bot container
API_URL=http://backend:4000/api

# Frontend panel URL for "Open Panel" button in Discord
PANEL_URL=https://yourdomain.com/dashboard
