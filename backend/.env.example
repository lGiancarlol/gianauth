# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) — uncomment and replace SQLite above
# DATABASE_URL="postgresql://user:password@localhost:5432/gianauth"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_strong_random_secret_in_production"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Allowed frontend origin (CORS)
FRONTEND_URL="http://localhost:3000"

# ── Discord (optional) ────────────────────────────────────────────────────────
# Webhook URL for request notifications (used when bot is NOT running)
DISCORD_WEBHOOK_URL=""

# Bot token — set this if you are running the discord bot
# The backend uses it to decide whether to include interactive buttons in webhook messages
DISCORD_BOT_TOKEN=""
