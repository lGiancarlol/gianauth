# ── GianAuth Discord Bot — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.

# ── Discord credentials ───────────────────────────────────────────────────────
# Bot token from: https://discord.com/developers/applications → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJvd25lciIsImlzQmxvY2tlZCI6ZmFsc2UsImlhdCI6MTc3ODk5Nzk0NiwiZXhwIjoxNzc5MDI2NzQ2fQ.M7tjBMgxrl_9Gj8fhTc5u6FL15LImEI0y6OtzPawJ_g

# Application (client) ID from: Discord Developer Portal → Your App → General Information
DISCORD_CLIENT_ID=1505442634422816838

# Channel ID where request notifications will be sent
# Enable Developer Mode in Discord: Settings → Advanced → Developer Mode
# Then right-click the target channel → Copy Channel ID
DISCORD_CHANNEL_ID=1505444567980183663

# (Optional) Role ID that can use admin slash commands and buttons
# If not set, ALL server members can use commands — set this in production
# Right-click a role in Server Settings → Copy Role ID
DISCORD_OWNER_ROLE_ID=

# ── Backend connection ────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
# Local development:
API_URL=http://localhost:4000/api
# Docker (bot inside compose network):
# API_URL=http://backend:4000/api

# Owner JWT token — used to authenticate API calls AND the Socket.IO connection from the bot
# Get it by logging in: POST /api/auth/login with admin credentials → copy "token"
# Note: tokens expire in 8h. For production, automate refresh or use a long-lived token.
OWNER_API_TOKEN=your_owner_jwt_token_here

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL shown in the "Open Panel" button on Discord embeds
PANEL_URL=http://localhost:3000/dashboard

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the backend SQLite database (used for persistent Discord message mapping)
# Leave empty to use the default: ../backend/prisma/dev.db
BOT_DB_PATH=
